{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "//": "SECURITY: every allowlist lives here. Only administrators edit it.",
  "Guard": {
    "Repositories": [
      {
        "Key": "sample-service",
        "CloneUrl": "https://git.internal.example.com/platform/sample-service.git",
        "BaseBranch": "main"
      },
      {
        "Key": "starwars-quotes",
        "CloneUrl": "https://github.com/thedigitaljedi86/starwars-quotes.git",
        "BaseBranch": "main"
      }
    ],
    "Packages": [
      "Serilog",
      "Newtonsoft.Json",
      "Polly"
    ],
    "AllowedTargetFrameworks": [
      "net8.0",
      "net9.0",
      "net10.0"
    ],
    "ContainerImages": [
      "registry.internal.example.com/devagent/worker-dotnet:8.0"
    ],
    "JobTypeImages": {
      "NuGetUpdate": "registry.internal.example.com/devagent/worker-dotnet:8.0",
      "DotNetUpgrade": "registry.internal.example.com/devagent/worker-dotnet:8.0"
    }
  }
}
