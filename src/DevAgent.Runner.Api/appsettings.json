{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "//ConnectionStrings": "Set to enable the admin-managed SQLite store (shared with the Hub via a volume). Without it, the Guard section below applies.",
  "ConnectionStrings": {
    "DevAgent": "Data Source=devagent.db"
  },

  "//Runner": "Sandbox mode: 'Stub' starts no containers; 'Cli' launches hardened throwaway workers via podman/docker. WorkerGitToken comes from the environment (Runner__Sandbox__WorkerGitToken), never from this file.",
  "Runner": {
    "Sandbox": {
      "Mode": "Stub",
      "Cli": "podman",
      "Network": "bridge",
      "Memory": "2g",
      "Cpus": "2",
      "PidsLimit": 512,
      "ContainerWorkspace": "/workspace",
      "McpGatewayBaseUrl": ""
    }
  },

  "//": "SECURITY: every allowlist lives here. Only administrators edit it.",
  "Guard": {
    "Repositories": [
      {
        "Key": "sample-service",
        "CloneUrl": "https://git.internal.example.com/platform/sample-service.git",
        "BaseBranch": "main"
      },
      {
        "Key": "starwars-quotes",
        "CloneUrl": "https://github.com/thedigitaljedi86/starwars-quotes.git",
        "BaseBranch": "main"
      }
    ],
    "Packages": [
      "Serilog",
      "Newtonsoft.Json",
      "Polly"
    ],
    "AllowedTargetFrameworks": [
      "net8.0",
      "net9.0",
      "net10.0"
    ],
    "ContainerImages": [
      "registry.internal.example.com/devagent/worker-dotnet:8.0"
    ],
    "JobTypeImages": {
      "NuGetUpdate": "registry.internal.example.com/devagent/worker-dotnet:8.0",
      "DotNetUpgrade": "registry.internal.example.com/devagent/worker-dotnet:8.0",
      "PipelineFix": "registry.internal.example.com/devagent/worker-dotnet:8.0",
      "DocUpdate": "registry.internal.example.com/devagent/worker-dotnet:8.0",
      "CodeReview": "registry.internal.example.com/devagent/worker-dotnet:8.0"
    }
  }
}
