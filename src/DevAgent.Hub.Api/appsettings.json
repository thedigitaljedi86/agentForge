{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Runner": {
    "BaseUrl": "http://localhost:5081"
  },

  "//": "Watch-list for the scheduled DotNetUpgrader agent. Keys must also be on the Runner's repository allowlist.",
  "DotNetUpgrader": {
    "RepositoryKeys": [ "sample-service", "starwars-quotes" ],
    "TargetFramework": "net10.0",
    "OnlyUpgrade": true
  }
}
